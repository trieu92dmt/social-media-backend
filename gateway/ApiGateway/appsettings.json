{
  "ReverseProxy": {
    "Routes": {
      "posts-route": {
        "ClusterId": "posts-cluster",
        "Match": {
          "Path": "/api/posts/{**catch-all}"
        }
      },

      "search-route": {
        "ClusterId": "search-cluster",
        "Match": {
          "Path": "/api/search/{**catch-all}"
        }
      }
    },

    "Clusters": {
      "posts-cluster": {
        "Destinations": {
          "destination1": {
            "Address": ""
          }
        }
      },

      "search-cluster": {
        "Destinations": {
          "destination1": {
            "Address": ""
          }
        }
      }
    }
  }
}